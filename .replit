modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "db-drift"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "live-chat-widget"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "portal-typecheck"

[[workflows.workflow]]
name = "test"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/portal run test"

[[workflows.workflow]]
name = "db-drift"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/db test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "live-chat-widget"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/support-config exec vitest run src/index.test.ts && pnpm --filter @workspace/portal exec vitest run src/config/support.test.ts src/components/chat/LiveChatLauncher.test.tsx src/components/chat/__tests__/LiveChatLauncher.test.tsx src/pages/admin/__tests__/SystemHealth.liveChatEmbedCard.test.tsx && pnpm --filter @workspace/api-server exec vitest run src/__tests__/live-chat-embed-health.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "portal-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node_modules/.bin/tsc -p artifacts/portal/tsconfig.json --noEmit > /tmp/ptc.log 2>&1; echo TYPECHECK_EXIT=$? >> /tmp/ptc.log"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 420000

[userenv]

[userenv.shared]

[userenv.production]
PORTAL_URL = "https://portal.buildtestscale.com"
VITE_TURNSTILE_SITE_KEY = "0x4AAAAAADg3k96t3Hwv0N5i"

[nix]
channel = "stable-25_05"
